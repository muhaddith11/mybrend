{
  "name": "libos",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "mobile": "turbo run dev --filter=@libos/mobile",
    "admin": "turbo run dev --filter=@libos/admin",
    "backend": "turbo run dev --filter=@libos/backend",
    "lint": "turbo run lint",
    "db:push": "cd backend && npx prisma db push",
    "db:studio": "cd backend && npx prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
