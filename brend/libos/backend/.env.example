DATABASE_URL="postgresql://user:password@localhost:5432/libos"
JWT_SECRET="your-secret-key-here"  # `openssl rand -hex 32` yoki `node -e "console.log(crypto.randomBytes(32).toString('hex'))"`
PORT=3001

# CORS — qaysi saytlar API'ni chaqira oladi
ALLOWED_ORIGINS=""        # vergul bilan: "zyff-web.vercel.app,zyff-admin.vercel.app"
STRICT_CORS="false"       # launchda "true" qiling — keng *.vercel.app ruxsati o'chadi

# Admin (do'kon egasi) login — ENV orqali
ADMIN_USERNAME=""         # admin login
ADMIN_PASSWORD=""         # admin parol
ADMIN_STORE_SLUG="asma"   # qaysi do'kon

# Sentry xato monitoringi (ixtiyoriy; kodda fallback bor)
SENTRY_DSN=""

# Cloudinary (rasm saqlash)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMS Gateway — Eskiz.uz (https://eskiz.uz)
ESKIZ_EMAIL=""       # Ro'yxatdan o'tgan email
ESKIZ_PASSWORD=""    # Parol
ESKIZ_FROM="4546"    # Sender name (Eskiz beradi)

# Click to'lov tizimi
# https://my.click.uz → Sozlamalar → Do'kon
CLICK_SERVICE_ID=""        # Merchant Service ID
CLICK_MERCHANT_ID=""       # Merchant ID
CLICK_SECRET_KEY=""        # Secret key (MD5 imzo uchun)
CLICK_MERCHANT_USER_ID=""  # Merchant user ID

# Payme to'lov tizimi
# https://merchant.payme.uz → Sozlamalar
PAYME_MERCHANT_ID=""       # Cashier ID
PAYME_SECRET_KEY=""        # Secret key (Basic Auth parol)
PAYME_TEST_SECRET_KEY=""   # Test muhit uchun
PAYME_IS_TEST="true"       # "false" — ishlab chiqarish muhiti
