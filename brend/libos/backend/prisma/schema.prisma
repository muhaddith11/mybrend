generator client {
  provider      = "prisma-client-js"
  // Vercel serverless runtime (AWS Lambda, Node 20) uchun engine ham yaratilsin
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentProvider {
  CLICK
  PAYME
  CASH
  TRANSFER // Bot orqali karta/QR o'tkazma — chek do'kon egasi tomonidan qo'lda tasdiqlanadi
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
}

enum Gender {
  MEN
  WOMEN
  KIDS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  DELIVERING
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  DELIVERY
  PICKUP
  CASH_ON_DOOR
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  avatar    String?
  otp       String?
  otpExpiry DateTime?
  lastOtpSentAt DateTime? // OTP rate-limit: oxirgi kod yuborilgan vaqt (spam oldini olish)
  otpAttempts   Int       @default(0) // noto'g'ri urinishlar soni (brute-force oldini olish)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  cart      CartItem[]
  favorites FavoriteStore[]
}

model Store {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  city        String   @default("Qo'qon")
  address     String
  phone       String
  logo        String?
  banner      String?
  isOpen      Boolean  @default(true)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Har bir do'kon o'z rangini tanlaydi (UI uchun)
  themeColor  String   @default("#534AB7")
  themeBg     String   @default("#EEEDFE")

  // Xaritadagi joylashuv
  lat           Float?
  lng           Float?

  // Telegram xabarnoma — buyurtma bildirishnomalari va bot-orqali to'lov tasdig'i
  // shu chat'ga boradi (do'kon egasining shaxsiy chat ID'si).
  telegramChatId String?

  // Bot orqali o'tkazma (TRANSFER) to'lovi uchun rekvizitlar. Mijoz checkout'da
  // "Bot orqali" ni tanlasa, bot shu kartani/QR'ni ko'rsatadi va pul to'g'ridan-
  // to'g'ri egasining kartasiga tushadi (platforma hisobidan o'tmaydi).
  cardNumber  String? // masalan "8600 1234 5678 9012"
  cardHolder  String? // karta egasining ismi
  paymentQr   String? // QR kod rasm URL (Supabase storage)

  // Do'kon qo'shimcha ma'lumotlari
  instagram    String?
  workingHours String?
  deliveryText String?

  // Qaysi bo'limlarda ko'rinadi
  genders   Gender[]

  // Xizmatlar
  hasDelivery Boolean @default(false)
  hasPickup   Boolean @default(false)
  hasCashOnDoor Boolean @default(true)
  deliveryTime  Int?    // daqiqalarda

  ownerId   String
  owner     StoreOwner @relation(fields: [ownerId], references: [id])

  products   Product[]
  orders     Order[]
  favorites  FavoriteStore[]
  categories Category[]

  @@index([genders])
}

model StoreOwner {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores    Store[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String
  gender   Gender

  // Kategoriya endi do'konga tegishli bo'lishi mumkin. storeId NULL bo'lsa —
  // global (barcha do'konlar ko'radigan) kategoriya, eski xulq bilan mos.
  // Shu sababli slug global emas, (storeId, slug) juftligi bo'yicha unikal.
  storeId  String?
  store    Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, slug])
}

model Product {
  id            String   @id @default(cuid())
  sku           String?  @unique
  name          String
  nameUz        String?
  description   String?
  descriptionUz String?
  price         Int
  originalPrice Int?
  images        String[]
  sizes         String[]
  colors        String[]
  inStock       Boolean  @default(true)
  featured      Boolean  @default(false)
  isNew         Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([storeId])
  @@index([categoryId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  size      String?
  color     String?
  quantity  Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String         @id @default(cuid())
  quantity  Int            @default(1)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?

  @@unique([userId, productId, variantId])
}

model Order {
  id            String       @id @default(cuid())
  totalPrice    Int
  status        OrderStatus  @default(PENDING)
  deliveryType  DeliveryType @default(DELIVERY)
  paymentMethod String?
  address       String?
  lat           Float?
  lng           Float?
  customerName  String?
  note          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  userId  String
  user    User    @relation(fields: [userId], references: [id])
  storeId String
  store   Store   @relation(fields: [storeId], references: [id])

  items   OrderItem[]
  payment Payment?

  // So'rovlar userId (/orders/my) va storeId (admin orders/stats) bo'yicha filtrlaydi —
  // buyurtmalar ko'payganда to'liq jadval skanini oldini olish uchun indeks.
  @@index([userId])
  @@index([storeId])
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Int
  size      String?
  color     String?
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Payment {
  id         String          @id @default(cuid())
  provider   PaymentProvider
  status     PaymentStatus   @default(PENDING)
  amount     BigInt          // tiyin (so'm × 100) — BigInt: yirik buyurtmada int4 overflow bo'lmasin

  // Click uchun
  clickTransId   String? @unique
  clickPaydocId  String?

  // Payme uchun
  paymeTransId   String? @unique
  paymeTime      BigInt?
  paymeCreateTime BigInt?
  paymePerformTime BigInt?
  paymeCancelTime  BigInt?
  paymeCancelReason Int?

  // Bot orqali o'tkazma (TRANSFER) uchun
  receiptFileId  String? // mijoz botga yuborgan chek rasmining Telegram file_id
  customerChatId String? // mijozning bot bilan chat ID'si (tasdiq/rad xabari uchun)
  customerPhone  String? // bot so'ragan telefon raqami (do'kon egasi bog'lanishi uchun)

  orderId    String  @unique
  order      Order   @relation(fields: [orderId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Login brute-force throttle holati (DB'da — serverless instance'lar bo'ylab umumiy).
// @fastify/rate-limit in-memory bo'lgani uchun Vercel'da yetarli emas edi.
model LoginThrottle {
  key         String   @id // masalan "admin:owner@example.com"
  count       Int      @default(0)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FavoriteStore {
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
}
